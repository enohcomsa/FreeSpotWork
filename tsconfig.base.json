{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@free-spot-service/app-date": ["libs/service/app-date/src/index.ts"],
      "@free-spot-service/auth": ["libs/service/auth/src/index.ts"],
      "@free-spot-service/booking": ["libs/service/booking/src/index.ts"],
      "@free-spot-service/building": ["libs/service/building/src/index.ts"],
      "@free-spot-service/event": ["libs/service/event/src/index.ts"],
      "@free-spot-service/faculty": ["libs/service/faculty/src/index.ts"],
      "@free-spot-service/floor": ["libs/service/floor/src/index.ts"],
      "@free-spot-service/group": ["libs/service/group/src/index.ts"],
      "@free-spot-service/room": ["libs/service/room/src/index.ts"],
      "@free-spot-service/user": ["libs/service/user/src/index.ts"],
      "@free-spot/admin": ["libs/pages/admin/src/index.ts"],
      "@free-spot/constants": ["libs/shared/constants/src/index.ts"],
      "@free-spot/dashboard": ["libs/pages/dashboard/src/index.ts"],
      "@free-spot/enums": ["libs/shared/enums/src/index.ts"],
      "@free-spot/models": ["libs/shared/models/src/index.ts"],
      "@free-spot/my-bookings": ["libs/pages/my-bookings/src/index.ts"],
      "@free-spot/schedule": ["libs/pages/schedule/src/index.ts"],
      "@free-spot/ui": ["libs/ui/src/index.ts"],
      "@free-spot/util": ["libs/util/src/index.ts"],
      "@http-free-spot/building": ["libs/http-free-spot/building/src/index.ts"],
      "@http-free-spot/event": ["libs/http-free-spot/event/src/index.ts"],
      "@http-free-spot/faculty": ["libs/http-free-spot/faculty/src/index.ts"],
      "@http-free-spot/floor": ["libs/http-free-spot/floor/src/index.ts"],
      "@http-free-spot/group": ["libs/http-free-spot/group/src/index.ts"],
      "@http-free-spot/room": ["libs/http-free-spot/room/src/index.ts"],
      "@http-free-spot/user": ["libs/http-free-spot/user/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
